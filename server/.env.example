# ============================================================
# TEMS Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to source control.
# ============================================================

# ── Node Environment ─────────────────────────────────────────
# Set to 'production' on the server. Controls CORS strictness,
# error detail visibility, and startup warnings.
NODE_ENV=development

# ── Server ───────────────────────────────────────────────────
PORT=2001

# ── Database ─────────────────────────────────────────────────
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=tems_user
DB_PASSWORD=your_secure_password_here
DB_NAME=tems

# ── Authentication ────────────────────────────────────────────
# AUTH_MODE=dev   → No login required. Auto-attaches first Admin user.
#                   DO NOT use in production.
# AUTH_MODE=sso   → JWT validation via SSO provider (Azure AD, Okta, etc.)
#                   Requires SSO_* variables below.
AUTH_MODE=dev

# ── SSO Configuration (required when AUTH_MODE=sso) ──────────
# SSO_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# SSO_AUDIENCE=api://{your-app-client-id}
# SSO_JWKS_URI=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Example: https://tems.yourdomain.com
# In development this is unused (all localhost/private IPs are allowed).
CORS_ORIGINS=http://localhost:2000

# ── Trust Proxy ───────────────────────────────────────────────
# Set to '1' if the server sits behind one reverse proxy hop (Nginx, AWS ALB).
# This ensures req.ip and rate limiting use the real client IP.
# Leave as 'false' (default) for direct connections.
TRUST_PROXY=false
