{
  "name": "tems-server",
  "version": "1.0.0",
  "description": "Telecom Expense Management System - API Server",
  "main": "server.js",
  "scripts": {
    "start": "node --max-old-space-size=8192 server.js",
    "dev": "nodemon --exec \"node --max-old-space-size=8192\" server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "knex": "^3.1.0",
    "multer": "^2.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
